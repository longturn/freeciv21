msgstr "σκληραγωγημένη"

#: data/royale/units.ruleset:76 data/royale/units.ruleset:2459
msgid "elite 1 (300%)"
msgstr ""

#: data/royale/units.ruleset:76 data/royale/units.ruleset:2459
