#: data/civ1/units.ruleset:414 data/civ2/units.ruleset:464
#: data/civ2civ3/units.ruleset:669 data/classic/units.ruleset:607
#: data/experimental/units.ruleset:629 data/multiplayer/units.ruleset:608
#: data/royale/units.ruleset:761 data/sandbox/units.ruleset:673
msgid ""
"This unit may be built from the start of the game. It is the weakest "
"offensive unit."
msgstr ""

#: data/civ1/units.ruleset:420 data/civ2/units.ruleset:470
#: data/civ2civ3/units.ruleset:675 data/classic/units.ruleset:613
#: data/experimental/units.ruleset:635 data/multiplayer/units.ruleset:614
#: data/royale/units.ruleset:767 data/sandbox/units.ruleset:679
msgid "Phalanx"
msgstr "Falanganoj"

#: data/civ1/units.ruleset:446 data/civ2/units.ruleset:496
#: data/civ2civ3/units.ruleset:701 data/classic/units.ruleset:639
#: data/experimental/units.ruleset:661 data/multiplayer/units.ruleset:640
#: data/royale/units.ruleset:793 data/sandbox/units.ruleset:705
msgid "The Phalanx is armored infantry, suitable for defending your cities."
msgstr ""

#: data/civ1/units.ruleset:451 data/civ2/units.ruleset:533
#: data/civ2civ3/units.ruleset:738 data/classic/units.ruleset:676
#: data/experimental/units.ruleset:698 data/multiplayer/units.ruleset:677
#: data/sandbox/units.ruleset:742
msgid "Legion"
msgstr "Legianoj"

#: data/civ1/units.ruleset:477 data/civ2/units.ruleset:559
#: data/civ2civ3/units.ruleset:764 data/classic/units.ruleset:702
#: data/experimental/units.ruleset:724 data/multiplayer/units.ruleset:703
#: data/sandbox/units.ruleset:768
msgid ""
"Legions are heavily armed and well disciplined infantry units with an "
"excellent offensive value."
msgstr ""

#: data/civ1/units.ruleset:483 data/civ2/units.ruleset:601
#: data/civ2civ3/units.ruleset:802 data/classic/units.ruleset:745
#: data/experimental/units.ruleset:767 data/multiplayer/units.ruleset:746
#: data/royale/units.ruleset:898 data/sandbox/units.ruleset:806
msgid "Musketeers"
msgstr "Musketistoj"

#: data/civ1/units.ruleset:510
msgid ""
"Musketeers are infantry equipped with early firearms and replace Phalanx as "
"the preferred city defender."
msgstr ""

#: data/civ1/units.ruleset:517 data/civ2/units.ruleset:742
#: data/civ2civ3/units.ruleset:836 data/classic/units.ruleset:851
#: data/experimental/units.ruleset:873 data/multiplayer/units.ruleset:887
#: data/royale/units.ruleset:932 data/sandbox/units.ruleset:840
