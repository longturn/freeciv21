#: ai/default/daicity.cpp:1019
#, fuzzy, c-format
msgid "%s is selling %s for %d."
msgid_plural "%s is selling %s for %d."
msgstr[0] "Tha %s a' reic %s (gun fheum a-nis) air %d a dh'òr."
msgstr[1] "Tha %s a' reic %s (gun fheum a-nis) air %d a dh'òr."
msgstr[2] "Tha %s a' reic %s (gun fheum a-nis) air %d a dh'òr."
msgstr[3] "Tha %s a' reic %s (gun fheum a-nis) air %d a dh'òr."

#: ai/default/daidiplomacy.cpp:352
#, c-format
msgid "*%s (AI)* In away mode AI can't sign such a treaty."
msgstr ""
"*%s (IF)* Chan urrainn dhan Inntinn Fhuadain ainm a chur ri cùmhnant mar seo "
"sa mhodh air falbh."

#: ai/default/daidiplomacy.cpp:363
#, c-format
msgid "*%s (AI)* First break alliance with %s, %s."
msgstr "*%s (IF)* Bris ur caidreachas le %s an toiseach, %s."

#: ai/default/daidiplomacy.cpp:372
#, c-format
msgid ""
"*%s (AI)* I would like to see you keep your distance from %s for some time, "
"%s."
msgstr "*%s (IF)* B' fhearr leam mura dig thu ro dhlùth air %s fad greis, %s."

#: ai/default/daidiplomacy.cpp:388
#, c-format
msgid "*%s (AI)* Let us first cease hostilities, %s."
msgstr "*%s (IF)* Sguireamaid dhen t-sabaid an toiseach, %s."

#: ai/default/daidiplomacy.cpp:393
#, c-format
msgid ""
"*%s (AI)* I wish to see you keep the current ceasefire for a bit longer "
"first, %s."
msgstr ""
"*%s (IF)* Bu toigh leam feitheamh greiseag an toiseach 's sibh a' cumail ris "
"an fhois-chogaidh, %s."

#: ai/default/daidiplomacy.cpp:417
#, c-format
msgid "*%s (AI)* I simply do not trust you with an alliance yet, %s."
msgstr ""
"*%s (IF)* Chan eil earbsa gu leòr agam ann an caidreachas còmhla ribh aig an "
"àm seo, %s."

#: ai/default/daidiplomacy.cpp:515
#, c-format
msgid "*%s (AI)* I do not know the city you mention."
msgstr "*%s (IF)* Chan eil mi eòlach air a' bhaile a thug sibh iomradh air."

#: ai/default/daidiplomacy.cpp:547
#, c-format
msgid "*%s (AI)* Sorry, sharing vision with you is not safe."
msgstr "*%s (IF)* Tha mi duilich, chan eil co-shealladh còmhla ribh sàbhailte."

#: ai/default/daidiplomacy.cpp:669
#, c-format
msgid "*%s (AI)* This deal was not very good for us, %s!"
msgstr "*%s (IF)* Cha robh am bargan seo ro mhath dhuinne, %s!"

#: ai/default/daidiplomacy.cpp:689
#, c-format
msgid "*%s (AI)* Welcome into our alliance %s!"
msgstr "*%s (IF)* Fàilte dhan chaidreachas còmhla rinn %s!"

#: ai/default/daidiplomacy.cpp:693
#, c-format
msgid "*%s (AI)* Yes, may we forever stand united, %s."
msgstr ""
"*%s (IF)* Aidh, seasaidh sinn an guailllibh a chèile gu sìorraidh bràth, %s."

#: ai/default/daidiplomacy.cpp:699
#, c-format
msgid "*%s (AI)* Yes, peace in our time!"
msgstr "*%s (IF)* Aidh, sìth nar linn!"

#: ai/default/daidiplomacy.cpp:705
#, c-format
msgid "*%s (AI)* Agreed. No more hostilities, %s."
msgstr "*%s (IF)* Tha mi a' dol leibh. Sguireamaid dhen t-sabaid, %s."

#: ai/default/daidiplomacy.cpp:989
#, c-format
msgid ""
"*%s (AI)* Greetings %s! May we suggest a ceasefire while we get to know each "
"other better?"
msgstr ""
"*%s (IF)* Fàilte oirbh %s! Saoil an aontaich sibh le fois-chogaidh fhad 's a "
"dh'fhàsas sinn nas eòlaiche air a chèile?"

#: ai/default/daidiplomacy.cpp:996
#, c-format
msgid ""
"*%s (AI)* I found you %s! Now make it worth my letting you live, or be "
"crushed."
msgstr ""

#: ai/default/daidiplomacy.cpp:1330
#, c-format
msgid "*%s (AI)* Space will never be yours. "
msgstr "*%s (IF)* Chan ann leibhse a bhios am fànas gu bràth."

#: ai/default/daidiplomacy.cpp:1336
#, c-format
msgid "*%s (AI)* I have tolerated your vicious antics long enough! To war!"
msgstr ""
"*%s (IF)* Dh'fhuiling mi ur cleasan nàimhdeil fada gu leòr! Cogadh gu bhith "
"eadarainn!"

#: ai/default/daidiplomacy.cpp:1342
#, c-format
msgid "*%s (AI)* Peace in ... some other time."
msgstr "*%s (IF)* Sìth nar... uaireigin eile."

#: ai/default/daidiplomacy.cpp:1349
#, c-format
msgid ""
"*%s (AI)* Finally I get around to you! Did you really think you could get "
"away with your crimes?"
msgstr ""
"*%s (IF)* 'S urrainn dhomh dèiligeadh ruibh mu dheireadh thall! An robh sibh "
"sa bheachd gun rachadh sibh às orm le ur n-eucoirean?"

#: ai/default/daidiplomacy.cpp:1356
#, c-format
msgid "*%s (AI)* Your covert hostilities brought this war upon you!"
msgstr ""
"*%s (IF)* 'S ann air sgàth ur nàimhdeas dìomhair a dh'èirich an cogadh seo!"

#: ai/default/daidiplomacy.cpp:1364
#, c-format
msgid "*%s (AI)* Your aggression against %s was your last mistake!"
msgstr ""
"*%s (IF)* Seo ur mearachd mu dheireadh 's sibh air ionnsaigh a thoirt air na "
"%s!"

#: ai/default/daidiplomacy.cpp:1452
#, c-format
msgid ""
"*%s (AI)* We will be launching an all-out war against %s in %d turn to stop "
"the spaceship launch."
msgid_plural ""
"*%s (AI)* We will be launching an all-out war against %s in %d turns to stop "
"the spaceship launch."
msgstr[0] ""
"*%s (IF)* Bidh sinn a' toirt ionnsaigh mhòr air %s ann an %d chuairt mus "
"cuir iad an soitheach-fhànais aca air bhog."
msgstr[1] ""
"*%s (IF)* Bidh sinn a' toirt ionnsaigh mhòr air %s ann an %d chuairt mus "
"cuir iad an soitheach-fhànais aca air bhog."
msgstr[2] ""
"*%s (AI)* Bidh sinn a' toirt ionnsaigh mhòr air %s ann an %d cuairtean mus "
"cuir iad an long-fhànais aca air bhog."
msgstr[3] ""
"*%s (AI)* Bidh sinn a' toirt ionnsaigh mhòr air %s ann an %d cuairt mus cuir "
"iad an long-fhànais aca air bhog."

#: ai/default/daidiplomacy.cpp:1462
#, c-format
msgid ""
"*%s (AI)* Your aid in this matter will be expected. Long live our glorious "
"alliance!"
msgstr ""
"*%s (IF)* Tha dùil againn ri ur taic sa chùis seo. Guma fada beò ar "
"caidreachas glòrmhor!"

#: ai/default/daidiplomacy.cpp:1470
#, c-format
msgid ""
"*%s (AI)* %s has grossly violated his treaties with us for own gain.  We "
"will answer in force in %d turn and expect you to honor your alliance with "
"us and do likewise!"
msgid_plural ""
"*%s (AI)* %s has grossly violated his treaties with us for own gain.  We "
"will answer in force in %d turns and expect you to honor your alliance with "
"us and do likewise!"
msgstr[0] ""
"*%s (IF)* Bhris %s na còrdaidhean eadarainn o bhun gu barr a chum a "
"bhuannachd fhèin. Bheir sinn ionnsaigh air ann an %d chuairt agus tha dùil "
"againn gun glèidh sibh ar caidreachas is gun toir sibhse ionnsaigh air "
"cuideachd!"
msgstr[1] ""
"*%s (IF)* Bhris %s na còrdaidhean eadarainn o bhun gu barr a chum a "
"bhuannachd fhèin. Bheir sinn ionnsaigh air ann an %d chuairt agus tha dùil "
"againn gun glèidh sibh ar caidreachas is gun toir sibhse ionnsaigh air "
"cuideachd!"
msgstr[2] ""
"*%s (AI)* Bhris %s na còrdaidhean eadarainn o bhun gu barr a chum a "
"bhuannachd fhèin. Bheir sinn ionnsaigh air ann an %d cuairtean agus tha dùil "
"againn gun glèidh sibh ar caidreachas is gun toir sibhse ionnsaigh air "
"cuideachd!"
msgstr[3] ""
"*%s (AI)* Bhris %s na còrdaidhean eadarainn o bhun gu barr a chum a "
"bhuannachd fhèin. Bheir sinn ionnsaigh air ann an %d cuairt agus tha dùil "
"againn gun glèidh sibh ar caidreachas is gun toir sibhse ionnsaigh air "
"cuideachd!"

#: ai/default/daidiplomacy.cpp:1484
#, c-format
msgid ""
"*%s (AI)* We intend to pillage and plunder the rich civilization of %s. We "
"declare war in %d turn."
msgid_plural ""
"*%s (AI)* We intend to pillage and plunder the rich civilization of %s. We "
"declare war in %d turns."
msgstr[0] ""
"*%s (IF)* Tha dùil againn a dhol air chreach is spùinn mhòr ann an dùthaich "
"bheartach %s. Bheir sinn ionnsaigh air ann an %d chuairt."
msgstr[1] ""
"*%s (IF)* Tha dùil againn a dhol air chreach is spùinn mhòr ann an dùthaich "
"bheartach %s. Bheir sinn ionnsaigh air ann an %d chuairt."
msgstr[2] ""
"*%s (AI)* Tha dùil againn a dhol air chreach is spùinn mhòr ann an dùthaich "
"bheartach %s. Bheir sinn ionnsaigh air ann an %d cuairtean."
msgstr[3] ""
"*%s (AI)* Tha dùil againn a dhol air chreach is spùinn mhòr ann an dùthaich "
"bheartach %s. Bheir sinn ionnsaigh air ann an %d cuairt."

#: ai/default/daidiplomacy.cpp:1491
#, c-format
msgid ""
"*%s (AI)* If you want a piece of the loot, feel free to join in the action!"
msgstr ""
"*%s (IF)* Ma tha sibh ag iarraidh cuid dhen chreach, siuthadaibh, gabhaibh "
"pàirt san iomairt!"

#: ai/default/daidiplomacy.cpp:1498
#, c-format
msgid ""
"*%s (AI)* We have had it with %s. Let us tear this pathetic civilization "
"apart. We declare war in %d turn."
msgid_plural ""
"*%s (AI)* We have had it with %s. Let us tear this pathetic civilization "
"apart. We declare war in %d turns."
msgstr[0] ""
"*%s (IF)* Tha sinn seachd searbh sgìth de %s. Reubamaid a' chùis-bhùirt de "
"shìobhaltas seo as a chèile. Bheir sinn ionnsaigh air ann an %d chuairt."
msgstr[1] ""
"*%s (AI)* Tha sinn seachd searbh sgìth de %s. Reubamaid a' chùis-bhùirt de "
"shìobhaltas seo as a chèile. Bheir sinn ionnsaigh air ann an %d chuairt."
msgstr[2] ""
"*%s (AI)* Tha sinn seachd searbh sgìth de %s. Reubamaid a' chùis-bhùirt de "
"shìobhaltas seo as a chèile. Bheir sinn ionnsaigh air ann an %d cuairtean."
msgstr[3] ""
"*%s (AI)* Tha sinn seachd searbh sgìth de %s. Reubamaid a' chùis-bhùirt de "
"shìobhaltas seo as a chèile. Bheir sinn ionnsaigh air ann an %d cuairt."

#: ai/default/daidiplomacy.cpp:1507
#, c-format
msgid "*%s (AI)* As our glorious allies, we expect your help in this war."
msgstr ""
"*%s (IF)* Tha dùil againn ri ur taic 's sibhse nar caidreabhach glòrmhor."

#: ai/default/daidiplomacy.cpp:1515
#, c-format
msgid ""
"*%s (AI)* We will honor our alliance and declare war on %s in %d turn.  Hold "
"on - we are coming!"
msgid_plural ""
"*%s (AI)* We will honor our alliance and declare war on %s in %d turns.  "
"Hold on - we are coming!"
msgstr[0] ""
"*%s (IF)* Glèidhidh sinn ar caidreachas is bheir sinn ionnsaigh air %s ann "
"an %d chuairt. Cum ort - tha sinn a' tighinn!"
msgstr[1] ""
"*%s (IF)* Glèidhidh sinn ar caidreachas is bheir sinn ionnsaigh air %s ann "
"an %d chuairt. Cum ort - tha sinn a' tighinn!"
msgstr[2] ""
"*%s (AI)* Glèidhidh sinn ar caidreachas is bheir sinn ionnsaigh air %s ann "
"an %d cuairtean. Cum ort - tha sinn a' tighinn!"
msgstr[3] ""
"*%s (AI)* Glèidhidh sinn ar caidreachas is bheir sinn ionnsaigh air %s ann "
"an %d cuairt. Cum ort - tha sinn a' tighinn!"

#: ai/default/daidiplomacy.cpp:1524
#, c-format
msgid ""
"*%s (AI)* We will honor our alliance with %s and declare war on %s in %d "
"turns.  We expect you to do likewise."
msgid_plural ""
"*%s (AI)* We will honor our alliance with %s and declare war on %s in %d "
"turns.  We expect you to do likewise."
msgstr[0] ""
"*%s (IF)* Glèidhidh sinn ar caidreachas le %s is bheir sinn ionnsaigh air %s "
"ann an %d chuairt. Tha dùil againn gun dèan sibhse an dearbh rud cuideachd."
msgstr[1] ""
"*%s (IF)* Glèidhidh sinn ar caidreachas le %s is bheir sinn ionnsaigh air %s "
"ann an %d chuairt. Tha dùil againn gun dèan sibhse an dearbh rud cuideachd."
msgstr[2] ""
"*%s (AI)* Glèidhidh sinn ar caidreachas le %s is bheir sinn ionnsaigh air %s "
"ann an %d cuairtean. Tha dùil againn gun dèan sibhse an dearbh rud cuideachd."
msgstr[3] ""
"*%s (AI)* Glèidhidh sinn ar caidreachas le %s is bheir sinn ionnsaigh air %s "
"ann an %d cuairt. Tha dùil againn gun dèan sibhse an dearbh rud cuideachd."

#: ai/default/daidiplomacy.cpp:1608
#, c-format
msgid ""
"*%s (AI)* Your attempt to conquer space for yourself alone betrays your true "
"intentions, and I will have no more of our alliance!"
msgstr ""
"*%s (IF)* Nochd sibh ur fìor-rùn 's sibhse a' feuchainn ris an fhànas a "
"cheannsachadh is tha sinn air ar sàrachadh leis a' chaidreachas eadarainn!"

#: ai/default/daidiplomacy.cpp:1624
#, c-format
msgid ""
"*%s (AI)* Your attempt to unilaterally dominate outer space is highly "
"offensive."
msgstr ""
"*%s (IF)* Tha sibh a' cur buaireas oirnn 's sibhse a' feuchainn ris an "
"fhànas iomallach a cheannsachadh nur n-aonar."

#: ai/default/daidiplomacy.cpp:1628
#, c-format
msgid ""
"*%s (AI)* If you do not stop constructing your spaceship, I may be forced to "
"take action!"
msgstr ""
"*%s (IF)* Mura sguireas sibh dhen a bhith a' togail soitheach-fhànais, "
"faodaidh gum bi agam ri rudeigin a dhèanamh!"

#: ai/default/daidiplomacy.cpp:1759
#, c-format
msgid "*%s (AI)* Sorry, sharing vision with you is no longer safe."
msgstr ""
"*%s (IF)* Tha mi duilich ach chan eil co-shealladh còmhla ribh sàbhailte "
"tuilleadh."

#: ai/default/daidiplomacy.cpp:1833
#, c-format
msgid ""
"*%s (AI)* Greetings our most trustworthy ally. We call upon you to destroy "
"our enemy, %s."
msgstr ""
"*%s (IF)* Fàilte oirbh, sibhse ur caidreabhas as dìlse. Tha sinn a' gairm "
"oirbh gus ar nàmhaid a sgriosadh, %s."

#: ai/default/daidiplomacy.cpp:1841
#, c-format
msgid ""
"*%s (AI)* Greetings ally, I see you have not yet made war with our enemy, "
"%s. Why do I need to remind you of your promises?"
msgstr ""
"*%s (IF)* Fàilte oirbh, a chaidreabhaich. Chì mi nach tug sibh ionnsaigh air "
"ar nàmhaid fhathast, %s. Carson a tha againn ri ur gealladh a thoirt nur "
"cuimhne?"

#: ai/default/daidiplomacy.cpp:1851
#, c-format
msgid ""
"*%s (AI)* Dishonored one, we made a pact of alliance, and yet you remain at "
"peace with our mortal enemy, %s! This is unacceptable; our alliance is no "
"more!"
msgstr ""
"*%s (IF)* Neach gun onair, rinn sinn aonta caidreachais ach tha sibh ann an "
"sìth le ar nàmhaid mhòr fhathast, %s! Cha seas sinn ri giùlan mar seo; tha "
"ar caidreachas crìochnaichte!"

#: ai/default/daidiplomacy.cpp:1885
#, c-format
msgid ""
"*%s (AI)* Greetings friend, may we suggest making a common cause and join in "
"an alliance?"
msgstr ""
"*%s (IF)* Fàilte oirbh, a charaid! An seas sibh còmhla rinn ann an "
"caidreachas?"

#: ai/default/daidiplomacy.cpp:1903
#, c-format
msgid "*%s (AI)* Greetings neighbor, may we suggest more peaceful relations?"
msgstr ""
"*%s (IF)* Fàilte oirbh, a nàbaidh! An aontaich sibh ri dàimh nas sìtheil?"

#: ai/default/daidiplomacy.cpp:1922
#, c-format
msgid ""
"*%s (AI)* We grow weary of this constant bloodshed. May we suggest a "
"cessation of hostilities?"
msgstr ""
"*%s (IF)* Tha sinn a' fàs sgìth dhen t-sìor-fhuileachas seo. Saoil an sguir "
"sinn dhen t-sabaid eadarainn?"

#: ai/default/daidiplomacy.cpp:2203
#, c-format
msgid ""
"*%s (AI)* We have been savagely attacked by %s, and we need your help! Honor "
"our glorious alliance and your name will never be forgotten!"
msgstr ""
"*%s (IF)* Chaidh ionnsaigh bhorb a thoirt oirnn le %s agus feumaidh sinn ur "
"cuideachadh! Cumaibh ri ar caidreachas glòrmhor agus mairidh ur n-ainm beò "
"gu sìorraidh bràth!"

#: ai/difficulty.cpp:237
#, fuzzy
msgid ""
"Toggles 'away' mode for your nation. In away mode, the AI will govern your "
"nation but make only minimal changes."
msgstr "Cumaidh an IF rian air do nàisean ach cha dèan e rudan mòra."

